{
  "expo": {
    "name": "Mi Despensa Market",
    "slug": "mi-despensa-market",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/brand/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/logo.png",
        "backgroundColor": "#fbf9f8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.diegoo.xs.midespensamarket"
    },
    "web": {
      "favicon": "./assets/brand/logo.png"
    },
    "plugins": [
      "expo-font",
      "./plugins/withAndroidNetworkSecurity",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fbf9f8",
          "image": "./assets/brand/logo.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "53c45277-a3bd-40c3-bd3d-f578f8d80345"
      }
    }
  }
}
